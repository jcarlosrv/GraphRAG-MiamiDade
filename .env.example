# Copy to .env and fill in. .env is gitignored; this file is committable.

# Anthropic API — needed for Phase 2 extraction and Phase 3 answer synthesis.
ANTHROPIC_API_KEY=

# Neo4j connection (defaults match a local Neo4j Community install).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Unset temporarily if you change EMBED_MODEL to one not yet downloaded.
HF_HUB_OFFLINE=1
